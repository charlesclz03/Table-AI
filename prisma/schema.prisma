generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// -------------------------------------------------------------------------------- //
// Core Usage: NextAuth Integration                                                 //
// -------------------------------------------------------------------------------- //

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("USER") // Options: "USER", "SUPERADMIN"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  preferences   UserPreferences?
  referrals     Referral[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// -------------------------------------------------------------------------------- //
// App Features: Generic User Preferences                                           //
// -------------------------------------------------------------------------------- //

model UserPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("system")
  language  String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// -------------------------------------------------------------------------------- //
// Monetization: Stripe Active Subscriptions                                        //
// -------------------------------------------------------------------------------- //

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  stripeCustomerId     String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId        String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")
  status               String?   // "active" | "canceled" | "past_due" | "incomplete"
  tier                 String    @default("FREE") // "FREE", "PRO"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ── Restaurant (managed via Supabase; minimal Prisma model for relation targets) ──

model Restaurant {
  id                   String   @id @default(cuid())
  email                String
  name                 String
  ownerId              String?  @map("owner_id")
  source               String?  @db.Text
  logoUrl              String?  @map("logo_url")
  soulMd               String?  @map("soul_md") @db.Text
  rulesMd              String?  @map("rules_md") @db.Text
  menuJson             Json?    @map("menu_json")
  quizAnswers          Json?    @map("quiz_answers")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  subscriptionStatus   String?  @map("subscription_status")
  planName             String?  @map("plan_name")
  setupPaidAt          DateTime? @map("setup_paid_at")
  billingStartsAt      DateTime? @map("billing_starts_at")
  qrCodeUrl            String?  @map("qr_code_url")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  referralCodes        ReferralCode[]
  referrerReferrals    Referral[]   @relation("Referrer")
  refereeReferrals     Referral[]   @relation("Referee")
}

// ── Referral System ──────────────────────────────────────────────────────────

/// One referral code per restaurant. Created when restaurant enables referrals.
model ReferralCode {
  id           String   @id @default(cuid())
  code         String   @unique // e.g. "GUSTIA-XYZ789"
  restaurantId String   @map(name: "restaurant_id")
  isActive     Boolean  @default(true) @map(name: "is_active")
  createdAt    DateTime @default(now()) @map(name: "created_at")
  updatedAt    DateTime @updatedAt @map(name: "updated_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map(name: "referral_codes")
}

/// Tracks referral relationships and reward status.
/// When a referred restaurant applies a code, a record is created here.
model Referral {
  id                   String    @id @default(cuid())
  referrerRestaurantId String    @map(name: "referrer_restaurant_id")
  refereeUserId        String    @map(name: "referee_user_id")
  refereeRestaurantId  String?   @map(name: "referee_restaurant_id")
  referredAt           DateTime  @default(now()) @map(name: "referred_at")

  // Rewards
  referrerFreeMonthGranted Boolean @default(false) @map(name: "referrer_free_month_granted")
  refereeFreeMonthGranted  Boolean @default(false) @map(name: "referee_free_month_granted")
  referrerGrantedAt        DateTime? @map(name: "referrer_granted_at")
  refereeGrantedAt         DateTime? @map(name: "referee_granted_at")

  referrerRestaurant Restaurant @relation("Referrer", fields: [referrerRestaurantId], references: [id], onDelete: Cascade)
  refereeUser        User       @relation(fields: [refereeUserId], references: [id], onDelete: Cascade)
  refereeRestaurant  Restaurant? @relation("Referee", fields: [refereeRestaurantId], references: [id], onDelete: SetNull)

  @@unique([referrerRestaurantId, refereeUserId])
  @@map(name: "referrals")
}
