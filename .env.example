# Application Domain
# Local development should stay on localhost. In production, set both
# NEXT_PUBLIC_SITE_URL and NEXTAUTH_URL to https://www.gustia.wine
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth Environment Variables
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_your_secret_with_openssl_rand_base64_32

# Google OAuth (For generic google sign in)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Supabase Databse Configuration (Production)
# DATABASE_URL = Connection Pooled (e.g. pgBouncer port 6543)
DATABASE_URL="postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL = Direct connection for Prisma Migrations/Seed (Db port 5432)
DIRECT_URL="postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require"

# (Optional) Supabase API access
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Supabase SSR middleware helpers are optional and additive.

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Local Price Definitions
STRIPE_PRICE_ID_MONTHLY=price_monthly_id
STRIPE_PRICE_ID_YEARLY=price_yearly_id

# OpenAI
OPENAI_API_KEY=sk-...

# InsForge Wizard Assistant Backend
# Base URL for the remote suggestion service. The app sends onboarding document
# snippets to ${INSFORGE_BASE_URL}/wizard-assistant/suggestions when configured.
INSFORGE_BASE_URL=https://insforge.example.com
INSFORGE_API_KEY=your_insforge_api_key
INSFORGE_TIMEOUT_MS=5000

# (Optional) Admins
# Comma-separated allowlist of emails to receive "SUPERADMIN" role
SUPERADMIN_EMAILS=
